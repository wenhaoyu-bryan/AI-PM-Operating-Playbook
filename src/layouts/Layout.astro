---
import '../styles/global.css';

interface Props {
  title: string;
  lang?: string;
  description?: string;
  pageWidth?: 'content' | 'wide' | 'full';
}

const { title, lang = 'en', description = '', pageWidth = 'content' } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const isEn = lang === 'en';
---

<!doctype html>
<html lang={lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} | AI PM Operating Playbook`} />
    <meta property="og:description" content={description || 'Practical frameworks, workflows, and case notes for AI Product Managers'} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title} | AI PM Operating Playbook</title>
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <!-- Nav -->
    <nav class="sticky top-0 z-50 bg-background/80 backdrop-blur-xl border-b border-border">
      <div class:list={[
        'mx-auto px-6 h-14 flex items-center justify-between',
        pageWidth === 'wide' ? 'max-w-[1440px]' : 'max-w-5xl'
      ]}>
        <a href={`${base}${lang}/`} class="font-semibold text-sm text-foreground no-underline tracking-tight flex items-center gap-2 hover:text-primary transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
          AI PM Operating Playbook
        </a>
        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-1 text-[13px]">
          <a href={`${base}${lang}/workbench/`} class="px-2.5 py-1.5 rounded-md text-emerald-400 font-medium hover:bg-emerald-500/10 transition-all">{isEn ? 'Workbench' : '工作台'}</a>
          <a href={`${base}${lang}/examples/`} class="px-2.5 py-1.5 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all">{isEn ? 'Examples' : '示例'}</a>
          <a href={`${base}${lang}/templates/`} class="px-2.5 py-1.5 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all">{isEn ? 'Templates' : '模板'}</a>
          <a href={isEn ? 'https://wenhaoyu-bryan.github.io/playbook/' : 'https://wenhaoyu-bryan.github.io/zh/playbook/'} class="px-2.5 py-1.5 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all" target="_blank" rel="noopener noreferrer">{isEn ? 'Methodology ↗' : '方法论 ↗'}</a>
          <a href={`${base}${lang}/industrial-agent-design-pattern/`} class="px-2.5 py-1.5 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all">{isEn ? 'Cases' : '案例'}</a>
          <a href="https://github.com/wenhaoyu-bryan/AI-PM-Operating-Playbook" class="p-2 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
          <span class="w-px h-4 bg-border mx-1"></span>
          <a href={isEn ? Astro.url.pathname.replace('/en/', '/zh-CN/') : Astro.url.pathname.replace('/zh-CN/', '/en/')} class="px-2.5 py-1.5 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all text-xs font-medium">
            {isEn ? '中文' : 'EN'}
          </a>
        </div>
        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="md:hidden p-2 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-colors" aria-label="Menu">
          <svg id="menu-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
          <svg id="close-icon" class="hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <!-- Mobile nav -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-background/95 backdrop-blur-xl">
        <div class="px-6 py-3 flex flex-col gap-1 text-sm">
          <a href={`${base}${lang}/workbench/`} class="px-3 py-2 rounded-md text-emerald-400 font-medium hover:bg-emerald-500/10 transition-all">{isEn ? 'Workbench' : '工作台'}</a>
          <a href={`${base}${lang}/examples/`} class="px-3 py-2 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all">{isEn ? 'Examples' : '示例'}</a>
          <a href={`${base}${lang}/templates/`} class="px-3 py-2 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all">{isEn ? 'Templates' : '模板'}</a>
          <a href={isEn ? 'https://wenhaoyu-bryan.github.io/playbook/' : 'https://wenhaoyu-bryan.github.io/zh/playbook/'} class="px-3 py-2 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all" target="_blank" rel="noopener noreferrer">{isEn ? 'Methodology ↗' : '方法论 ↗'}</a>
          <a href={`${base}${lang}/industrial-agent-design-pattern/`} class="px-3 py-2 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all">{isEn ? 'Cases' : '案例'}</a>
          <a href="https://github.com/wenhaoyu-bryan/AI-PM-Operating-Playbook" class="px-3 py-2 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all inline-flex items-center gap-2" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
          <span class="h-px bg-border my-1"></span>
          <a href={isEn ? Astro.url.pathname.replace('/en/', '/zh-CN/') : Astro.url.pathname.replace('/zh-CN/', '/en/')} class="px-3 py-2 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all text-xs font-medium">
            {isEn ? '中文' : 'EN'}
          </a>
        </div>
      </div>
    </nav>

    <!-- Main -->
    <main class:list={[
      'mx-auto px-6 py-10',
      pageWidth === 'content' && 'max-w-5xl',
      pageWidth === 'wide' && 'max-w-[1440px]',
      pageWidth === 'full' && 'max-w-full',
    ]}>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-border mt-20">
      <div class:list={[
        'mx-auto px-6 py-8 text-center text-xs text-muted-foreground',
        pageWidth === 'wide' ? 'max-w-[1440px]' : 'max-w-5xl'
      ]}>
        <span>{isEn ? 'AI PM Operating Playbook · Interactive tools and practical methodology by Wenhao Yu.' : 'AI PM Operating Playbook · Wenhao Yu 的 AI 产品方法论与交互工具集。'}</span>
        <div class="mt-3 flex items-center justify-center gap-4">
          <a href={isEn ? 'https://wenhaoyu-bryan.github.io/' : 'https://wenhaoyu-bryan.github.io/zh/'} class="text-muted-foreground hover:text-foreground transition-colors no-underline" target="_blank" rel="noopener noreferrer">{isEn ? 'Personal Website' : '个人主页'}</a>
          <span class="text-border">·</span>
          <a href="https://github.com/wenhaoyu-bryan/AI-PM-Operating-Playbook" class="text-muted-foreground hover:text-foreground transition-colors no-underline" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
    </footer>

    <script>
      // Mobile menu toggle
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuIcon = document.getElementById('menu-icon');
      const closeIcon = document.getElementById('close-icon');
      if (menuBtn && mobileMenu && menuIcon && closeIcon) {
        menuBtn.addEventListener('click', () => {
          const isOpen = !mobileMenu.classList.contains('hidden');
          mobileMenu.classList.toggle('hidden');
          menuIcon.classList.toggle('hidden', !isOpen);
          closeIcon.classList.toggle('hidden', isOpen);
        });
      }

    </script>
  </body>
</html>
