---
import '../styles/global.css';

interface Props {
  title: string;
  lang?: string;
  description?: string;
}

const { title, lang = 'en', description = '' } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const isEn = lang === 'en';
---

<!doctype html>
<html lang={lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title} | AI PM Operating Playbook</title>
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <!-- Reading progress bar -->
    <div id="reading-progress" class="fixed top-0 left-0 w-full h-[2px] z-[60]">
      <div id="reading-progress-bar" class="h-full bg-emerald-500 origin-left transition-[transform] duration-150 ease-out" style="transform: scaleX(0); width: 100%;"></div>
    </div>

    <!-- Nav -->
    <nav class="sticky top-0 z-50 bg-background/80 backdrop-blur-xl border-b border-border">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href={`${base}${lang}/`} class="font-semibold text-sm text-foreground no-underline tracking-tight flex items-center gap-2 hover:text-primary transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
          AI PM Playbook
        </a>
        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-1 text-[13px]">
          <a href={`${base}${lang}/ai-pm-role/`} class="px-2.5 py-1.5 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all">Thinking</a>
          <a href={`${base}${lang}/vibe-coding/`} class="px-2.5 py-1.5 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all">Delivery</a>
          <a href={`${base}${lang}/harness-engineering/`} class="px-2.5 py-1.5 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all">Agents</a>
          <a href={`${base}${lang}/prompt-to-ontology/`} class="px-2.5 py-1.5 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all">Cases</a>
          <a href={`${base}${lang}/canvas/`} class="px-2.5 py-1.5 rounded-md text-emerald-400 font-medium hover:bg-emerald-500/10 transition-all">Canvas</a>
          <span class="w-px h-4 bg-border mx-1"></span>
          <a href={isEn ? Astro.url.pathname.replace('/en/', '/zh-CN/') : Astro.url.pathname.replace('/zh-CN/', '/en/')} class="px-2.5 py-1.5 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all text-xs font-medium">
            {isEn ? '中文' : 'EN'}
          </a>
        </div>
        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="md:hidden p-2 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-colors" aria-label="Menu">
          <svg id="menu-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
          <svg id="close-icon" class="hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <!-- Mobile nav -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-background/95 backdrop-blur-xl">
        <div class="px-6 py-3 flex flex-col gap-1 text-sm">
          <a href={`${base}${lang}/ai-pm-role/`} class="px-3 py-2 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all">Thinking</a>
          <a href={`${base}${lang}/vibe-coding/`} class="px-3 py-2 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all">Delivery</a>
          <a href={`${base}${lang}/harness-engineering/`} class="px-3 py-2 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all">Agents</a>
          <a href={`${base}${lang}/prompt-to-ontology/`} class="px-3 py-2 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all">Cases</a>
          <a href={`${base}${lang}/canvas/`} class="px-3 py-2 rounded-md text-emerald-400 font-medium hover:bg-emerald-500/10 transition-all">Canvas</a>
          <span class="h-px bg-border my-1"></span>
          <a href={isEn ? Astro.url.pathname.replace('/en/', '/zh-CN/') : Astro.url.pathname.replace('/zh-CN/', '/en/')} class="px-3 py-2 rounded-md text-muted-foreground hover:text-foreground hover:bg-secondary transition-all text-xs font-medium">
            {isEn ? '中文' : 'EN'}
          </a>
        </div>
      </div>
    </nav>

    <!-- Main -->
    <main class="max-w-5xl mx-auto px-6 py-10">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-border mt-20">
      <div class="max-w-5xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-muted-foreground">
        <span>AI PM Operating Playbook &middot; MIT License</span>
        <div class="flex items-center gap-4">
          <a href="https://github.com/wenhaoyu-bryan/AI-PM-Operating-Playbook" class="hover:text-foreground transition-colors">GitHub</a>
          <a href={`${base}${lang}/ai_pm_case_study_template/`} class="hover:text-foreground transition-colors">Templates</a>
          <a href={`${base}${lang}/books/`} class="hover:text-foreground transition-colors">Resources</a>
        </div>
      </div>
    </footer>

    <script>
      // Mobile menu toggle
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuIcon = document.getElementById('menu-icon');
      const closeIcon = document.getElementById('close-icon');
      if (menuBtn && mobileMenu && menuIcon && closeIcon) {
        menuBtn.addEventListener('click', () => {
          const isOpen = !mobileMenu.classList.contains('hidden');
          mobileMenu.classList.toggle('hidden');
          menuIcon.classList.toggle('hidden', !isOpen);
          closeIcon.classList.toggle('hidden', isOpen);
        });
      }

      // Reading progress bar
      const bar = document.getElementById('reading-progress-bar');
      if (bar) {
        const update = () => {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const progress = docHeight > 0 ? Math.min(scrollTop / docHeight, 1) : 0;
          bar.style.transform = `scaleX(${progress})`;
        };
        window.addEventListener('scroll', update, { passive: true });
        update();
      }
    </script>
  </body>
</html>
