---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Examples — AI PM Operating Playbook" description="Real AI product concept examples to explore" lang="en">
  <div class="space-y-6">
    <div class="mb-10">
      <h1 class="text-3xl font-bold mb-3">Example Concepts</h1>
      <p class="text-muted-foreground max-w-2xl">Explore illustrative AI product concepts structured through the Workbench. Click any example to open it with all fields pre-filled.</p>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      <!-- Card 1: Prompt-to-Ontology -->
      <div class="bg-card rounded-xl ring-1 ring-foreground/10 p-6 flex flex-col">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center text-sm font-bold" style="background: oklch(0.45 0.15 160 / 0.2); color: oklch(0.75 0.15 160);">1</div>
          <h2 class="text-lg font-semibold">Prompt-to-Ontology</h2>
        </div>
        <p class="text-sm text-muted-foreground mb-4 flex-1">Turn messy business concepts into structured ontology assets through AI-assisted schema extraction. Great for enterprise knowledge management products.</p>
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="px-2 py-0.5 rounded-full bg-secondary text-xs text-muted-foreground">ontology-knowledge</span>
          <span class="px-2 py-0.5 rounded-full bg-secondary text-xs text-muted-foreground">schema extraction</span>
        </div>
        <a href="/AI-PM-Operating-Playbook/en/workbench/" onclick="sessionStorage.setItem('ai-pm-load-example','prompt-to-ontology')" class="inline-flex items-center gap-1.5 text-sm font-medium text-emerald-400 hover:text-emerald-300 transition-colors">
          Open in Workbench
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12"/></svg>
        </a>
      </div>

      <!-- Card 2: Industrial Agent Decision Support -->
      <div class="bg-card rounded-xl ring-1 ring-foreground/10 p-6 flex flex-col">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center text-sm font-bold" style="background: oklch(0.55 0.15 200 / 0.2); color: oklch(0.75 0.15 200);">2</div>
          <h2 class="text-lg font-semibold">Industrial Agent Decision Support</h2>
        </div>
        <p class="text-sm text-muted-foreground mb-4 flex-1">Diagnose manufacturing equipment issues with AI-assisted multi-step workflows. Combines sensor data, maintenance history, and engineering knowledge.</p>
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="px-2 py-0.5 rounded-full bg-secondary text-xs text-muted-foreground">agent</span>
          <span class="px-2 py-0.5 rounded-full bg-secondary text-xs text-muted-foreground">industrial AI</span>
        </div>
        <a href="/AI-PM-Operating-Playbook/en/workbench/" onclick="sessionStorage.setItem('ai-pm-load-example','industrial-agent')" class="inline-flex items-center gap-1.5 text-sm font-medium text-emerald-400 hover:text-emerald-300 transition-colors">
          Open in Workbench
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12"/></svg>
        </a>
      </div>

      <!-- Card 3: RAG Knowledge Assistant -->
      <div class="bg-card rounded-xl ring-1 ring-foreground/10 p-6 flex flex-col">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center text-sm font-bold" style="background: oklch(0.6 0.15 260 / 0.2); color: oklch(0.75 0.15 260);">3</div>
          <h2 class="text-lg font-semibold">RAG Knowledge Assistant</h2>
        </div>
        <p class="text-sm text-muted-foreground mb-4 flex-1">Help employees find answers from internal documentation using retrieval-augmented generation. Grounded in company wikis, policies, and project docs.</p>
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="px-2 py-0.5 rounded-full bg-secondary text-xs text-muted-foreground">RAG</span>
          <span class="px-2 py-0.5 rounded-full bg-secondary text-xs text-muted-foreground">knowledge access</span>
        </div>
        <a href="/AI-PM-Operating-Playbook/en/workbench/" onclick="sessionStorage.setItem('ai-pm-load-example','rag-knowledge-assistant')" class="inline-flex items-center gap-1.5 text-sm font-medium text-emerald-400 hover:text-emerald-300 transition-colors">
          Open in Workbench
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12"/></svg>
        </a>
      </div>

      <!-- Card 4: Customer Feedback Classification -->
      <div class="bg-card rounded-xl ring-1 ring-foreground/10 p-6 flex flex-col">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center text-sm font-bold" style="background: oklch(0.65 0.12 320 / 0.2); color: oklch(0.75 0.12 320);">4</div>
          <h2 class="text-lg font-semibold">Customer Feedback Classification</h2>
        </div>
        <p class="text-sm text-muted-foreground mb-4 flex-1">Classify incoming customer feedback into a controlled taxonomy so teams can route issues and identify trends. A deterministic classification workflow — no agent required.</p>
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="px-2 py-0.5 rounded-full bg-secondary text-xs text-muted-foreground">classification</span>
          <span class="px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-400 text-xs font-medium">Non-Agent</span>
        </div>
        <a href="/AI-PM-Operating-Playbook/en/workbench/" onclick="sessionStorage.setItem('ai-pm-load-example','customer-feedback-classification')" class="inline-flex items-center gap-1.5 text-sm font-medium text-emerald-400 hover:text-emerald-300 transition-colors">
          Open in Workbench
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5-5 5M6 12h12"/></svg>
        </a>
      </div>
    </div>
  </div>
</Layout>
