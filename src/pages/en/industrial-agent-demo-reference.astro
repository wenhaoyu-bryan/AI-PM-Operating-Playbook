---
import Layout from '../../layouts/Layout.astro';
import IndustrialRCADemo from '../../components/IndustrialRCADemo';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<Layout title="Industrial RCA Agent Interactive Demo" lang="en" description="Try a simulated RCA agent workflow: anomaly case → investigation plan → tool calls → evidence → HITL review → final report → evaluation.">
  <nav class="mb-8">
    <a href={`${base}en/`} class="text-xs text-muted-foreground hover:text-foreground transition-colors inline-flex items-center gap-1">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Back to Playbook
    </a>
  </nav>
  <div class="mb-6 rounded-lg bg-emerald-500/10 ring-1 ring-emerald-500/20 p-4">
    <p class="text-sm text-emerald-400 m-0">
      This is a deterministic product walkthrough, not a live AI system. It shows how an industrial RCA agent workflow can be designed from an AI PM perspective.
    </p>
  </div>
  <article class="prose prose-invert max-w-none">
    <IndustrialRCADemo lang="en" client:load />
  </article>
</Layout>
