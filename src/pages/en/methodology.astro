---
import Layout from '../../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<Layout title="Methodology — AI PM Operating Playbook" lang="en" description="The thinking framework behind the AI PM Operating Playbook">
  <div class="space-y-8">
    <h1 class="text-3xl font-bold mb-3">Methodology</h1>
    <p class="text-muted-foreground mb-10 max-w-2xl">The methodology content has moved to Wenhao Yu's personal website.</p>

    <div class="bg-card rounded-xl ring-1 ring-foreground/10 p-6 space-y-4">
      <p class="text-muted-foreground">
        The Vibe Coding, Harness Engineering, and Agent Product Design articles are now published as part of the AI PM Operating Playbook on the personal site.
      </p>
      <p class="text-muted-foreground">
        The AI PM Operating Playbook is still available here as an interactive tool.
      </p>
    </div>

    <!-- CTA -->
    <div class="mt-10 p-5 rounded-xl ring-1 ring-emerald-500/20 bg-emerald-500/5 text-center">
      <p class="text-sm text-muted-foreground mb-3">Read the methodology articles on the personal website</p>
      <a href="https://wenhaoyu-bryan.github.io/playbook/" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium transition-colors no-underline">
        Visit Playbook
      </a>
      <a href={`${base}en/workbench/`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg ring-1 ring-emerald-500/30 hover:bg-emerald-500/10 text-emerald-400 text-sm font-medium transition-colors no-underline ml-3">
        Open Workbench
      </a>
    </div>
  </div>
</Layout>
