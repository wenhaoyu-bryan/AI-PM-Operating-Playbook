---
import Layout from '../../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const steps = [
  { num: '1', title: 'Frame the Product', desc: 'Define the user, problem, and business context' },
  { num: '2', title: 'Design the AI Workflow', desc: 'Choose the right AI capability and workflow' },
  { num: '3', title: 'Define Evaluation and Risk', desc: 'Set metrics, risks, and acceptance criteria' },
  { num: '4', title: 'Export the Handoff Pack', desc: 'Generate 6 structured starter artifacts' },
];

const outputs = [
  { title: 'AI Product Brief', desc: 'Structured summary of the product concept', icon: 'brief' },
  { title: 'Workflow Specification', desc: 'Step-by-step AI/agent workflow with Mermaid diagram', icon: 'workflow' },
  { title: 'Evaluation Plan', desc: 'Metrics, datasets, and review processes', icon: 'eval' },
  { title: 'Acceptance Criteria', desc: 'Testable criteria for prototype and production', icon: 'criteria' },
  { title: 'Coding Agent Handoff', desc: 'Implementation brief optimized for AI coding tools', icon: 'handoff' },
  { title: 'CLAUDE.md Starter', desc: 'Project context file for Claude Code', icon: 'claude' },
];

const examples = [
  {
    title: 'Prompt-to-Ontology',
    desc: 'Turn messy business concepts into structured ontology assets',
    key: 'prompt-to-ontology',
    tag: 'Ontology / Knowledge',
    scenario: 'Knowledge Management',
    challenge: 'Turn ambiguous business terminology into a structured, machine-readable ontology.',
  },
  {
    title: 'Industrial Agent Decision Support',
    desc: 'Diagnose manufacturing equipment issues with AI-assisted workflows',
    key: 'industrial-agent',
    tag: 'Agent',
    scenario: 'Industrial AI',
    challenge: 'Combine evidence from multiple systems while keeping high-impact actions under human control.',
  },
  {
    title: 'RAG Knowledge Assistant',
    desc: 'Help employees find answers from internal documentation',
    key: 'rag-knowledge-assistant',
    tag: 'RAG',
    scenario: 'Enterprise Knowledge',
    challenge: 'Help employees find accurate answers without surfacing sensitive or outdated content.',
  },
];

const iconPaths: Record<string, string> = {
  brief: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8',
  workflow: 'M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z M13 2v7h7 M6 13h4 M6 17h4 M13 13h4 M13 17h4',
  eval: 'M18 20V10 M12 20V4 M6 20v-6',
  criteria: 'M9 11l3 3L22 4 M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11',
  handoff: 'M22 2L11 13 M22 2l-7 20-4-9-9-4 20-7z',
  claude: 'M12 2a7 7 0 0 1 7 7c0 2.38-1.19 4.47-3 5.74V17a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 0 1 7-7zM9 21h6M10 17v4M14 17v4',
};
---

<Layout title="AI PM Operating Playbook" lang="en" description="A privacy-friendly toolkit that helps AI Product Managers turn product concepts into structured briefs, workflow specifications, evaluation plans, and coding-agent handoffs.">

  <!-- Section 1: Hero -->
  <section class="text-center py-20 max-w-3xl mx-auto">
    <p class="text-xs font-medium text-emerald-400 uppercase tracking-widest mb-4">AI PM Operating Playbook</p>
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-5">Turn an AI product idea into structured delivery artifacts</h1>
    <p class="text-lg text-muted-foreground leading-relaxed mb-8">
      Frame the problem, design the AI workflow, define evaluation and human review, then export a reusable handoff pack for your team or coding agent.
    </p>
    <div class="flex items-center justify-center gap-3 flex-wrap">
      <a href={`${base}en/workbench/`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium transition-colors no-underline">
        Open Quick Tools
      </a>
      <a href={`${base}en/examples/`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg ring-1 ring-foreground/15 hover:ring-foreground/30 text-sm font-medium transition-colors no-underline">
        View Examples
      </a>
    </div>
    <div class="mt-4 flex items-center justify-center gap-4">
      <a href="https://wenhaoyu-bryan.github.io/playbook/" class="text-xs text-muted-foreground hover:text-foreground transition-colors no-underline" target="_blank" rel="noopener noreferrer">
        Read the Methodology ↗
      </a>
      <span class="text-xs text-border">·</span>
      <a href="https://github.com/wenhaoyu-bryan/AI-PM-Operating-Playbook" class="text-xs text-muted-foreground hover:text-foreground transition-colors no-underline">
        View GitHub
      </a>
    </div>
  </section>

  <!-- Workbench Preview Mockup (interactive) -->
  <section class="mb-20 max-w-4xl mx-auto hidden md:block">
    <div class="rounded-xl ring-1 ring-foreground/10 bg-card overflow-hidden">
      <!-- Mock toolbar -->
      <div class="flex items-center gap-3 px-4 py-2.5 border-b border-border text-xs text-muted-foreground">
        <span class="font-medium text-foreground">Industrial Agent Decision Support</span>
        <span class="text-foreground/30">|</span>
        <span>Agent</span>
        <span class="ml-auto">Draft in progress &middot; Saved locally</span>
      </div>
      <div class="flex min-h-[280px]">
        <!-- Mock sidebar -->
        <div id="mock-sidebar" role="tablist" aria-label="Workflow steps" class="w-44 shrink-0 border-r border-border p-3 space-y-2 text-xs">
          <button type="button" role="tab" aria-selected="true" data-step="1" class="mock-step w-full flex items-center gap-2 rounded-md px-1.5 py-1 transition-colors text-left cursor-pointer text-emerald-400 bg-emerald-500/5">
            <span class="w-5 h-5 rounded-full bg-emerald-500/20 flex items-center justify-center text-[10px] font-medium">1</span> Product Framing
          </button>
          <button type="button" role="tab" aria-selected="false" data-step="2" class="mock-step w-full flex items-center gap-2 rounded-md px-1.5 py-1 transition-colors text-left cursor-pointer text-muted-foreground hover:text-foreground hover:bg-secondary/50">
            <span class="w-5 h-5 rounded-full bg-secondary flex items-center justify-center text-[10px] font-medium">2</span> AI Workflow
          </button>
          <button type="button" role="tab" aria-selected="false" data-step="3" class="mock-step w-full flex items-center gap-2 rounded-md px-1.5 py-1 transition-colors text-left cursor-pointer text-muted-foreground hover:text-foreground hover:bg-secondary/50">
            <span class="w-5 h-5 rounded-full bg-secondary flex items-center justify-center text-[10px] font-medium">3</span> Evaluation
          </button>
          <button type="button" role="tab" aria-selected="false" data-step="4" class="mock-step w-full flex items-center gap-2 rounded-md px-1.5 py-1 transition-colors text-left cursor-pointer text-muted-foreground hover:text-foreground hover:bg-secondary/50">
            <span class="w-5 h-5 rounded-full bg-secondary flex items-center justify-center text-[10px] font-medium">4</span> Export
          </button>
        </div>

        <!-- Mock form panels -->
        <div class="flex-1 border-r border-border relative">
          <!-- Step 1: Product Framing -->
          <div data-panel="1" role="tabpanel" class="mock-panel absolute inset-0 p-4 space-y-3 overflow-hidden">
            <div class="text-xs font-semibold uppercase tracking-wider text-foreground/50">Problem Context</div>
            <div class="space-y-2">
              <div class="space-y-1"><div class="text-xs text-muted-foreground">Business Scenario</div><div class="h-14 rounded bg-secondary/50"></div></div>
              <div class="space-y-1"><div class="text-xs text-muted-foreground">Target User</div><div class="h-9 rounded bg-secondary/50"></div></div>
              <div class="space-y-1"><div class="text-xs text-muted-foreground">Decision to Support</div><div class="h-9 rounded bg-secondary/50"></div></div>
            </div>
          </div>
          <!-- Step 2: AI Workflow -->
          <div data-panel="2" role="tabpanel" aria-hidden="true" class="mock-panel absolute inset-0 p-4 space-y-3 overflow-hidden opacity-0 pointer-events-none">
            <div class="text-xs font-semibold uppercase tracking-wider text-foreground/50">AI / Agent Workflow</div>
            <div class="space-y-2">
              <div class="space-y-1"><div class="text-xs text-muted-foreground">AI Capability</div><div class="h-9 rounded bg-secondary/50"></div></div>
              <div class="space-y-1"><div class="text-xs text-muted-foreground">Agent Decision</div><div class="flex gap-2"><div class="h-8 flex-1 rounded bg-emerald-500/10 ring-1 ring-emerald-500/20"></div><div class="h-8 flex-1 rounded bg-secondary/50"></div></div></div>
              <div class="space-y-1"><div class="text-xs text-muted-foreground">Workflow Steps</div><div class="h-16 rounded bg-secondary/50"></div></div>
              <div class="space-y-1"><div class="text-xs text-muted-foreground">Human Review</div><div class="h-9 rounded bg-secondary/50"></div></div>
            </div>
          </div>
          <!-- Step 3: Evaluation -->
          <div data-panel="3" role="tabpanel" aria-hidden="true" class="mock-panel absolute inset-0 p-4 space-y-3 overflow-hidden opacity-0 pointer-events-none">
            <div class="text-xs font-semibold uppercase tracking-wider text-foreground/50">Evaluation &amp; Risk</div>
            <div class="space-y-2">
              <div class="space-y-1"><div class="text-xs text-muted-foreground">Evaluation Metrics</div><div class="h-12 rounded bg-secondary/50"></div></div>
              <div class="space-y-1"><div class="text-xs text-muted-foreground">Evaluation Scenarios</div><div class="h-12 rounded bg-secondary/50"></div></div>
              <div class="space-y-1"><div class="text-xs text-muted-foreground">Acceptance Criteria</div><div class="h-9 rounded bg-secondary/50"></div></div>
            </div>
          </div>
          <!-- Step 4: Export -->
          <div data-panel="4" role="tabpanel" aria-hidden="true" class="mock-panel absolute inset-0 p-4 space-y-3 overflow-hidden opacity-0 pointer-events-none">
            <div class="text-xs font-semibold uppercase tracking-wider text-foreground/50">Export Documents</div>
            <div class="grid grid-cols-2 gap-2">
              <div class="rounded-lg ring-1 ring-foreground/8 p-2.5"><div class="text-[11px] font-medium text-foreground mb-0.5">Product Brief</div><div class="h-1.5 w-3/4 rounded bg-secondary"></div></div>
              <div class="rounded-lg ring-1 ring-foreground/8 p-2.5"><div class="text-[11px] font-medium text-foreground mb-0.5">Workflow Spec</div><div class="h-1.5 w-2/3 rounded bg-secondary"></div></div>
              <div class="rounded-lg ring-1 ring-foreground/8 p-2.5"><div class="text-[11px] font-medium text-foreground mb-0.5">Evaluation Plan</div><div class="h-1.5 w-3/4 rounded bg-secondary"></div></div>
              <div class="rounded-lg ring-1 ring-foreground/8 p-2.5"><div class="text-[11px] font-medium text-foreground mb-0.5">Acceptance Criteria</div><div class="h-1.5 w-1/2 rounded bg-secondary"></div></div>
              <div class="rounded-lg ring-1 ring-foreground/8 p-2.5"><div class="text-[11px] font-medium text-foreground mb-0.5">Coding Agent Handoff</div><div class="h-1.5 w-2/3 rounded bg-secondary"></div></div>
              <div class="rounded-lg ring-1 ring-foreground/8 p-2.5"><div class="text-[11px] font-medium text-foreground mb-0.5">CLAUDE.md Starter</div><div class="h-1.5 w-3/5 rounded bg-secondary"></div></div>
            </div>
          </div>
        </div>

        <!-- Mock preview panels -->
        <div class="w-72 shrink-0 relative">
          <!-- Preview 1: Product Brief -->
          <div data-preview="1" role="tabpanel" class="mock-preview absolute inset-0 p-4 overflow-hidden">
            <div class="text-xs font-semibold text-foreground/50 mb-2">Live Preview</div>
            <div class="space-y-2 text-xs text-muted-foreground">
              <div class="font-semibold text-foreground text-sm">AI Product Brief</div>
              <div class="h-2 w-3/4 rounded bg-secondary"></div>
              <div class="h-2 w-full rounded bg-secondary"></div>
              <div class="h-2 w-5/6 rounded bg-secondary"></div>
              <div class="h-2 w-2/3 rounded bg-secondary"></div>
              <div class="mt-3 font-semibold text-foreground text-sm">Business Problem</div>
              <div class="h-2 w-full rounded bg-secondary"></div>
              <div class="h-2 w-4/5 rounded bg-secondary"></div>
            </div>
          </div>
          <!-- Preview 2: Workflow Spec -->
          <div data-preview="2" role="tabpanel" aria-hidden="true" class="mock-preview absolute inset-0 p-4 overflow-hidden opacity-0 pointer-events-none">
            <div class="text-xs font-semibold text-foreground/50 mb-2">Live Preview</div>
            <div class="space-y-2 text-xs text-muted-foreground">
              <div class="font-semibold text-foreground text-sm">Workflow Specification</div>
              <div class="h-2 w-4/5 rounded bg-secondary"></div>
              <div class="h-2 w-full rounded bg-secondary"></div>
              <div class="mt-3 flex items-center gap-1.5">
                <div class="h-5 w-16 rounded bg-emerald-500/15 ring-1 ring-emerald-500/20"></div>
                <div class="w-3 h-px bg-foreground/20"></div>
                <div class="h-5 w-16 rounded bg-emerald-500/15 ring-1 ring-emerald-500/20"></div>
                <div class="w-3 h-px bg-foreground/20"></div>
                <div class="h-5 w-16 rounded bg-emerald-500/15 ring-1 ring-emerald-500/20"></div>
              </div>
              <div class="mt-2 h-2 w-full rounded bg-secondary"></div>
              <div class="h-2 w-5/6 rounded bg-secondary"></div>
              <div class="mt-3 font-semibold text-foreground text-sm">Tools &amp; Boundaries</div>
              <div class="h-2 w-full rounded bg-secondary"></div>
              <div class="h-2 w-3/4 rounded bg-secondary"></div>
            </div>
          </div>
          <!-- Preview 3: Evaluation Plan -->
          <div data-preview="3" role="tabpanel" aria-hidden="true" class="mock-preview absolute inset-0 p-4 overflow-hidden opacity-0 pointer-events-none">
            <div class="text-xs font-semibold text-foreground/50 mb-2">Live Preview</div>
            <div class="space-y-2 text-xs text-muted-foreground">
              <div class="font-semibold text-foreground text-sm">Evaluation Plan</div>
              <div class="h-2 w-3/4 rounded bg-secondary"></div>
              <div class="h-2 w-full rounded bg-secondary"></div>
              <div class="mt-3 font-semibold text-foreground text-sm">Test Scenarios</div>
              <div class="flex flex-wrap gap-1 mt-1">
                <div class="h-4 w-14 rounded-full bg-emerald-500/10"></div>
                <div class="h-4 w-16 rounded-full bg-emerald-500/10"></div>
                <div class="h-4 w-12 rounded-full bg-emerald-500/10"></div>
              </div>
              <div class="mt-2 font-semibold text-foreground text-sm">Acceptance Criteria</div>
              <div class="h-2 w-full rounded bg-secondary"></div>
              <div class="h-2 w-4/5 rounded bg-secondary"></div>
            </div>
          </div>
          <!-- Preview 4: Export -->
          <div data-preview="4" role="tabpanel" aria-hidden="true" class="mock-preview absolute inset-0 p-4 overflow-hidden opacity-0 pointer-events-none">
            <div class="text-xs font-semibold text-foreground/50 mb-2">Live Preview</div>
            <div class="space-y-3 text-xs text-muted-foreground">
              <div class="font-semibold text-foreground text-sm">Design Review</div>
              <div class="flex items-center gap-2">
                <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] bg-amber-500/15 text-amber-400 font-medium">1 warning</span>
                <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] bg-blue-500/15 text-blue-400 font-medium">2 suggestions</span>
              </div>
              <div class="mt-3 font-semibold text-foreground text-sm">Generated Documents</div>
              <div class="h-2 w-full rounded bg-secondary"></div>
              <div class="h-2 w-5/6 rounded bg-secondary"></div>
              <div class="h-2 w-4/5 rounded bg-secondary"></div>
              <div class="mt-3 flex gap-2">
                <div class="h-7 w-20 rounded-md bg-emerald-600/80"></div>
                <div class="h-7 w-20 rounded-md bg-secondary"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <p class="text-center text-xs text-muted-foreground mt-3">Click steps 1–4 to preview the workflow</p>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const buttons = document.querySelectorAll<HTMLButtonElement>('.mock-step');
      const panels = document.querySelectorAll<HTMLElement>('.mock-panel');
      const previews = document.querySelectorAll<HTMLElement>('.mock-preview');

      function switchStep(step: string) {
        buttons.forEach(btn => {
          const isActive = btn.dataset.step === step;
          const numSpan = btn.querySelector('span');
          btn.setAttribute('aria-selected', String(isActive));
          if (isActive) {
            btn.className = 'mock-step w-full flex items-center gap-2 rounded-md px-1.5 py-1 transition-colors text-left cursor-pointer text-emerald-400 bg-emerald-500/5';
            if (numSpan) numSpan.className = 'w-5 h-5 rounded-full bg-emerald-500/20 flex items-center justify-center text-[10px] font-medium';
          } else {
            btn.className = 'mock-step w-full flex items-center gap-2 rounded-md px-1.5 py-1 transition-colors text-left cursor-pointer text-muted-foreground hover:text-foreground hover:bg-secondary/50';
            if (numSpan) numSpan.className = 'w-5 h-5 rounded-full bg-secondary flex items-center justify-center text-[10px] font-medium';
          }
        });
        panels.forEach(p => {
          const isActive = p.dataset.panel === step;
          p.style.opacity = isActive ? '1' : '0';
          p.style.pointerEvents = isActive ? 'auto' : 'none';
          p.setAttribute('aria-hidden', String(!isActive));
        });
        previews.forEach(p => {
          const isActive = p.dataset.preview === step;
          p.style.opacity = isActive ? '1' : '0';
          p.style.pointerEvents = isActive ? 'auto' : 'none';
          p.setAttribute('aria-hidden', String(!isActive));
        });
      }

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          if (btn.dataset.step) switchStep(btn.dataset.step);
        });
      });
    });
  </script>

  <!-- Section 2: How It Works -->
  <section class="mb-20">
    <h2 class="text-xs font-semibold text-muted-foreground uppercase tracking-widest text-center mb-10">How It Works</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 relative">
      <!-- Connector line (desktop only) -->
      <div class="hidden md:block absolute top-6 left-[12.5%] right-[12.5%] h-px bg-foreground/10 z-0" />
      {steps.map((step) => (
        <div class="relative z-10 flex flex-col items-center text-center">
          <div class="w-12 h-12 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center text-lg font-bold mb-3">
            {step.num}
          </div>
          <h3 class="text-sm font-semibold text-foreground mb-1">{step.title}</h3>
          <p class="text-xs text-muted-foreground leading-relaxed m-0">{step.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Section 3: What You Get -->
  <section class="mb-20">
    <h2 class="text-xs font-semibold text-muted-foreground uppercase tracking-widest text-center mb-10">What You Get</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
      {outputs.map((item) => (
        <div class="bg-card rounded-xl ring-1 ring-foreground/10 p-5">
          <div class="w-9 h-9 rounded-lg bg-emerald-500/10 flex items-center justify-center text-emerald-400 mb-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d={iconPaths[item.icon]} />
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-foreground mb-1">{item.title}</h3>
          <p class="text-xs text-muted-foreground leading-relaxed m-0">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Section 4: Example Concepts -->
  <section class="mb-20">
    <h2 class="text-xs font-semibold text-muted-foreground uppercase tracking-widest text-center mb-10">Example Concepts</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      {examples.map((ex) => (
        <div class="bg-card rounded-xl ring-1 ring-foreground/10 p-5 flex flex-col">
          <h3 class="text-sm font-semibold text-foreground mb-2">{ex.title}</h3>
          <div class="flex items-center gap-2 mb-2">
            <span class="inline-flex px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-400 text-[10px] font-medium">{ex.tag}</span>
            <span class="text-[10px] text-muted-foreground">&middot;</span>
            <span class="text-[10px] text-muted-foreground">{ex.scenario}</span>
          </div>
          <p class="text-xs text-muted-foreground leading-relaxed m-0 mb-4 flex-1">Challenge: {ex.challenge}</p>
          <a
            href={`${base}en/workbench/`}
            onclick={`sessionStorage.setItem('ai-pm-load-example', '${ex.key}')`}
            class="inline-flex items-center gap-1.5 text-xs font-medium text-emerald-400 hover:text-emerald-300 transition-colors no-underline"
          >
            Open in Quick Tools
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- Section 5: Case Modules -->
  <section class="mb-20">
    <h2 class="text-xs font-semibold text-muted-foreground uppercase tracking-widest text-center mb-10">Case Modules</h2>
    <div class="max-w-2xl mx-auto bg-card rounded-xl ring-1 ring-foreground/10 p-6">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center text-emerald-400">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-foreground">Industrial Agent Design Pattern</h3>
          <p class="text-xs text-muted-foreground">Why industrial agents are not chatbots — with an interactive RCA agent demo you can try</p>
        </div>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
        <a href={`${base}en/industrial-agent-design-pattern/`} class="block px-3 py-2 rounded-lg bg-secondary hover:bg-secondary/80 text-xs font-medium text-foreground transition-colors no-underline">Overview</a>
        <a href={`${base}en/quality-anomaly-rca-case/`} class="block px-3 py-2 rounded-lg bg-secondary hover:bg-secondary/80 text-xs font-medium text-foreground transition-colors no-underline">RCA Case</a>
