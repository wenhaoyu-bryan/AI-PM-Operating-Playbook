---
import Layout from '../../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const steps = [
  { num: '1', title: 'Frame the Product', desc: 'Define the user, problem, and business context' },
  { num: '2', title: 'Design the AI Workflow', desc: 'Choose the right AI capability and workflow' },
  { num: '3', title: 'Define Evaluation and Risk', desc: 'Set metrics, risks, and acceptance criteria' },
  { num: '4', title: 'Export the Handoff Pack', desc: 'Generate 6 structured starter artifacts' },
];

const outputs = [
  { title: 'AI Product Brief', desc: 'Structured summary of the product concept', icon: 'brief' },
  { title: 'Workflow Specification', desc: 'Step-by-step AI/agent workflow with Mermaid diagram', icon: 'workflow' },
  { title: 'Evaluation Plan', desc: 'Metrics, datasets, and review processes', icon: 'eval' },
  { title: 'Acceptance Criteria', desc: 'Testable criteria for prototype and production', icon: 'criteria' },
  { title: 'Coding Agent Handoff', desc: 'Implementation brief optimized for AI coding tools', icon: 'handoff' },
  { title: 'CLAUDE.md Starter', desc: 'Project context file for Claude Code', icon: 'claude' },
];

const examples = [
  {
    title: 'Prompt-to-Ontology',
    desc: 'Turn messy business concepts into structured ontology assets',
    key: 'prompt-to-ontology',
    tag: 'Ontology / Knowledge',
    scenario: 'Knowledge Management',
    challenge: 'Turn ambiguous business terminology into a structured, machine-readable ontology.',
  },
  {
    title: 'Industrial Agent Decision Support',
    desc: 'Diagnose manufacturing equipment issues with AI-assisted workflows',
    key: 'industrial-agent',
    tag: 'Agent',
    scenario: 'Industrial AI',
    challenge: 'Combine evidence from multiple systems while keeping high-impact actions under human control.',
  },
  {
    title: 'RAG Knowledge Assistant',
    desc: 'Help employees find answers from internal documentation',
    key: 'rag-assistant',
    tag: 'RAG',
    scenario: 'Enterprise Knowledge',
    challenge: 'Help employees find accurate answers without surfacing sensitive or outdated content.',
  },
];

const iconPaths: Record<string, string> = {
  brief: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8',
  workflow: 'M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z M13 2v7h7 M6 13h4 M6 17h4 M13 13h4 M13 17h4',
  eval: 'M18 20V10 M12 20V4 M6 20v-6',
  criteria: 'M9 11l3 3L22 4 M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11',
  handoff: 'M22 2L11 13 M22 2l-7 20-4-9-9-4 20-7z',
  claude: 'M12 2a7 7 0 0 1 7 7c0 2.38-1.19 4.47-3 5.74V17a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 0 1 7-7zM9 21h6M10 17v4M14 17v4',
};
---

<Layout title="AI PM Workbench" lang="en" description="A static, privacy-friendly workbench that helps AI PMs turn fuzzy product concepts into briefs, evaluation plans, and coding agent handoffs.">

  <!-- Section 1: Hero -->
  <section class="text-center py-20 max-w-3xl mx-auto">
    <p class="text-xs font-medium text-emerald-400 uppercase tracking-widest mb-4">AI PM Workbench</p>
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-5">Turn an AI product idea into structured delivery artifacts</h1>
    <p class="text-lg text-muted-foreground leading-relaxed mb-8">
      Frame the problem, design the AI workflow, define evaluation and human review, then export a reusable handoff pack for your team or coding agent.
    </p>
    <div class="flex items-center justify-center gap-3 flex-wrap">
      <a href={`${base}en/workbench/`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium transition-colors no-underline">
        Start a New Project
      </a>
      <a href={`${base}en/examples/`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg ring-1 ring-foreground/15 hover:ring-foreground/30 text-sm font-medium transition-colors no-underline">
        Open an Example
      </a>
    </div>
    <div class="mt-4">
      <a href="https://github.com/wenhaoyu-bryan/AI-PM-Workbench" class="text-xs text-muted-foreground hover:text-foreground transition-colors no-underline">
        View GitHub
      </a>
    </div>
  </section>

  <!-- Workbench Preview Mockup -->
  <section class="mb-20 max-w-4xl mx-auto hidden md:block">
    <div class="rounded-xl ring-1 ring-foreground/10 bg-card overflow-hidden">
      <!-- Mock toolbar -->
      <div class="flex items-center gap-3 px-4 py-2.5 border-b border-border text-xs text-muted-foreground">
        <span class="font-medium text-foreground">Industrial Agent Decision Support</span>
        <span class="text-foreground/30">|</span>
        <span>Agent</span>
        <span class="ml-auto">8 of 26 fields &middot; Saved locally</span>
      </div>
      <div class="flex">
        <!-- Mock sidebar -->
        <div class="w-44 shrink-0 border-r border-border p-3 space-y-2 text-xs">
          <div class="flex items-center gap-2 text-emerald-400"><span class="w-5 h-5 rounded-full bg-emerald-500/20 flex items-center justify-center text-[10px]">1</span> Product Framing</div>
          <div class="flex items-center gap-2 text-muted-foreground"><span class="w-5 h-5 rounded-full bg-secondary flex items-center justify-center text-[10px]">2</span> AI Workflow</div>
          <div class="flex items-center gap-2 text-muted-foreground"><span class="w-5 h-5 rounded-full bg-secondary flex items-center justify-center text-[10px]">3</span> Evaluation</div>
          <div class="flex items-center gap-2 text-muted-foreground"><span class="w-5 h-5 rounded-full bg-secondary flex items-center justify-center text-[10px]">4</span> Export</div>
        </div>
        <!-- Mock form -->
        <div class="flex-1 p-4 space-y-3 border-r border-border">
          <div class="text-xs font-semibold uppercase tracking-wider text-foreground/50">Problem Context</div>
          <div class="space-y-2">
            <div class="space-y-1"><div class="text-xs text-muted-foreground">Business Scenario</div><div class="h-16 rounded bg-secondary/50"></div></div>
            <div class="space-y-1"><div class="text-xs text-muted-foreground">Target User</div><div class="h-10 rounded bg-secondary/50"></div></div>
            <div class="space-y-1"><div class="text-xs text-muted-foreground">Decision to Support</div><div class="h-10 rounded bg-secondary/50"></div></div>
          </div>
        </div>
        <!-- Mock preview -->
        <div class="w-72 shrink-0 p-4">
          <div class="text-xs font-semibold text-foreground/50 mb-2">Live Preview</div>
          <div class="space-y-2 text-xs text-muted-foreground">
            <div class="font-semibold text-foreground text-sm">AI Product Brief</div>
            <div class="h-2 w-3/4 rounded bg-secondary"></div>
            <div class="h-2 w-full rounded bg-secondary"></div>
            <div class="h-2 w-5/6 rounded bg-secondary"></div>
            <div class="h-2 w-2/3 rounded bg-secondary"></div>
            <div class="mt-3 font-semibold text-foreground text-sm">Business Problem</div>
            <div class="h-2 w-full rounded bg-secondary"></div>
            <div class="h-2 w-4/5 rounded bg-secondary"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: How It Works -->
  <section class="mb-20">
    <h2 class="text-xs font-semibold text-muted-foreground uppercase tracking-widest text-center mb-10">How It Works</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 relative">
      <!-- Connector line (desktop only) -->
      <div class="hidden md:block absolute top-6 left-[12.5%] right-[12.5%] h-px bg-foreground/10 z-0" />
      {steps.map((step) => (
        <div class="relative z-10 flex flex-col items-center text-center">
          <div class="w-12 h-12 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center text-lg font-bold mb-3">
            {step.num}
          </div>
          <h3 class="text-sm font-semibold text-foreground mb-1">{step.title}</h3>
          <p class="text-xs text-muted-foreground leading-relaxed m-0">{step.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Section 3: What You Get -->
  <section class="mb-20">
    <h2 class="text-xs font-semibold text-muted-foreground uppercase tracking-widest text-center mb-10">What You Get</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
      {outputs.map((item) => (
        <div class="bg-card rounded-xl ring-1 ring-foreground/10 p-5">
          <div class="w-9 h-9 rounded-lg bg-emerald-500/10 flex items-center justify-center text-emerald-400 mb-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d={iconPaths[item.icon]} />
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-foreground mb-1">{item.title}</h3>
          <p class="text-xs text-muted-foreground leading-relaxed m-0">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Section 4: Example Concepts -->
  <section class="mb-20">
    <h2 class="text-xs font-semibold text-muted-foreground uppercase tracking-widest text-center mb-10">Example Concepts</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      {examples.map((ex) => (
        <div class="bg-card rounded-xl ring-1 ring-foreground/10 p-5 flex flex-col">
          <h3 class="text-sm font-semibold text-foreground mb-2">{ex.title}</h3>
          <div class="flex items-center gap-2 mb-2">
            <span class="inline-flex px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-400 text-[10px] font-medium">{ex.tag}</span>
            <span class="text-[10px] text-muted-foreground">&middot;</span>
            <span class="text-[10px] text-muted-foreground">{ex.scenario}</span>
          </div>
          <p class="text-xs text-muted-foreground leading-relaxed m-0 mb-4 flex-1">Challenge: {ex.challenge}</p>
          <a
            href={`${base}en/workbench/`}
            onclick={`sessionStorage.setItem('ai-pm-load-example', '${ex.key}')`}
            class="inline-flex items-center gap-1.5 text-xs font-medium text-emerald-400 hover:text-emerald-300 transition-colors no-underline"
          >
            Open in Workbench
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- Section 5: Author -->
  <section class="mb-8">
    <div class="p-5 rounded-xl ring-1 ring-foreground/10 bg-card">
      <h3 class="text-sm font-semibold text-foreground mb-1">Built by Wenhao Yu</h3>
      <p class="text-xs text-muted-foreground leading-relaxed m-0 mb-3">
        AI Product Manager focused on industrial agents, ontology-driven systems, and AI-native prototyping.
      </p>
      <div class="flex items-center gap-3">
        <a href="https://wenhaoyu-bryan.github.io/" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md bg-secondary hover:bg-secondary/80 text-xs font-medium transition-colors no-underline" target="_blank" rel="noopener">View Portfolio</a>
        <a href="https://github.com/wenhaoyu-bryan" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md ring-1 ring-foreground/10 hover:ring-foreground/20 text-xs font-medium transition-colors no-underline" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </section>

</Layout>
