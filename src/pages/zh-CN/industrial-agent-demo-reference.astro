---
import Layout from '../../layouts/Layout.astro';
import IndustrialRCADemo from '../../components/IndustrialRCADemo';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<Layout title="工业 RCA Agent 交互式 Demo" lang="zh-CN" description="体验一个模拟 RCA Agent 工作流：异常案例 → 调查计划 → 工具调用 → 证据链 → 人工审核 → 最终报告 → 评估结果。">
  <nav class="mb-8">
    <a href={`${base}zh-CN/`} class="text-xs text-muted-foreground hover:text-foreground transition-colors inline-flex items-center gap-1">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      返回操作手册
    </a>
  </nav>
  <article class="prose prose-invert max-w-none">
    <IndustrialRCADemo lang="zh" client:load />
  </article>
</Layout>
