---
import Layout from '../../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<Layout title="方法论 — AI PM 操作手册" lang="zh-CN" description="AI PM 操作手册背后的思维框架">
  <div class="space-y-8">
    <h1 class="text-3xl font-bold mb-3">方法论</h1>
    <p class="text-muted-foreground mb-10 max-w-2xl">方法论内容已迁移至余文豪的个人网站。</p>

    <div class="bg-card rounded-xl ring-1 ring-foreground/10 p-6 space-y-4">
      <p class="text-muted-foreground">
        Vibe Coding、Harness Engineering 和智能体产品设计的文章已发布在个人网站，作为 AI PM Operating Playbook 的一部分。
      </p>
      <p class="text-muted-foreground">
        AI PM 操作手册的交互工具仍可在此使用。
      </p>
    </div>

    <!-- CTA -->
    <div class="mt-10 p-5 rounded-xl ring-1 ring-emerald-500/20 bg-emerald-500/5 text-center">
      <p class="text-sm text-muted-foreground mb-3">在个人网站阅读方法论文章</p>
      <a href="https://wenhaoyu-bryan.github.io/playbook/" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium transition-colors no-underline">
        访问 Playbook
      </a>
      <a href={`${base}zh-CN/workbench/`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg ring-1 ring-emerald-500/30 hover:bg-emerald-500/10 text-emerald-400 text-sm font-medium transition-colors no-underline ml-3">
        打开工作台
      </a>
    </div>
  </div>
</Layout>
