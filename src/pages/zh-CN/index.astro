---
import Layout from '../../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const steps = [
  { num: '1', title: '定义产品', desc: '明确用户、问题和业务背景' },
  { num: '2', title: '设计 AI 工作流', desc: '选择合适的 AI 能力和工作流' },
  { num: '3', title: '明确评估与风险', desc: '设定指标、风险和验收标准' },
  { num: '4', title: '导出交付材料', desc: '生成 6 份可复用的结构化初稿' },
];

const outputs = [
  { title: 'AI 产品简报', desc: '产品概念的结构化摘要', icon: 'brief' },
  { title: '工作流规格说明', desc: '逐步的 AI/智能体工作流及 Mermaid 流程图', icon: 'workflow' },
  { title: '评估方案', desc: '指标、数据集和审核流程', icon: 'eval' },
  { title: '验收标准', desc: '原型和生产环境的可测试标准', icon: 'criteria' },
  { title: '编码智能体交付物', desc: '针对 AI 编码工具优化的实施简报', icon: 'handoff' },
  { title: 'CLAUDE.md 起始模板', desc: '面向 Claude Code 的项目上下文文件', icon: 'claude' },
];

const examples = [
  {
    title: 'Prompt-to-Ontology',
    desc: '将杂乱的业务概念转化为结构化的本体资产',
    key: 'prompt-to-ontology',
    tag: '本体/知识',
    scenario: '知识管理',
    challenge: '将模糊的业务术语转化为结构化、机器可读的本体。',
  },
  {
    title: '工业智能体决策支持',
    desc: '借助 AI 辅助工作流诊断制造设备问题',
    key: 'industrial-agent',
    tag: '智能体',
    scenario: '工业 AI',
    challenge: '整合多系统证据，同时将高影响操作置于人工控制之下。',
  },
  {
    title: 'RAG 知识助手',
    desc: '帮助员工从内部文档中快速找到答案',
    key: 'rag-knowledge-assistant',
    tag: 'RAG',
    scenario: '企业知识',
    challenge: '帮助员工找到准确答案，同时避免暴露敏感或过时内容。',
  },
];

const iconPaths: Record<string, string> = {
  brief: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8',
  workflow: 'M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z M13 2v7h7 M6 13h4 M6 17h4 M13 13h4 M13 17h4',
  eval: 'M18 20V10 M12 20V4 M6 20v-6',
  criteria: 'M9 11l3 3L22 4 M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11',
  handoff: 'M22 2L11 13 M22 2l-7 20-4-9-9-4 20-7z',
  claude: 'M12 2a7 7 0 0 1 7 7c0 2.38-1.19 4.47-3 5.74V17a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 0 1 7-7zM9 21h6M10 17v4M14 17v4',
};
---

<Layout title="AI PM 操作手册" lang="zh-CN" description="一个隐私友好的工具集，帮助 AI 产品经理将产品概念转化为结构化的产品简报、工作流规范、评估计划和编码智能体交付材料。">

  <!-- Section 1: Hero -->
  <section class="text-center py-20 max-w-3xl mx-auto">
    <p class="text-xs font-medium text-emerald-400 uppercase tracking-widest mb-4">AI PM 操作手册</p>
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-5">将 AI 产品想法转化为结构化交付材料</h1>
    <p class="text-lg text-muted-foreground leading-relaxed mb-8">
      定义业务问题，设计 AI 工作流，明确评估与人工审核，并生成可交付给团队或编码智能体的完整材料。
    </p>
    <div class="flex items-center justify-center gap-3 flex-wrap">
      <a href={`${base}zh-CN/workbench/`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium transition-colors no-underline">
        打开快速工具
      </a>
      <a href={`${base}zh-CN/examples/`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg ring-1 ring-foreground/15 hover:ring-foreground/30 text-sm font-medium transition-colors no-underline">
        查看示例
      </a>
    </div>
    <div class="mt-4 flex items-center justify-center gap-4">
      <a href="https://wenhaoyu-bryan.github.io/zh/playbook/" class="text-xs text-muted-foreground hover:text-foreground transition-colors no-underline" target="_blank" rel="noopener noreferrer">
        阅读方法论 ↗
      </a>
    </div>
  </section>

  <!-- 工作台预览交互 Mockup -->
  <section class="mb-20 max-w-4xl mx-auto hidden md:block">
    <div class="rounded-xl ring-1 ring-foreground/10 bg-card overflow-hidden">
      <!-- Mock toolbar -->
      <div class="flex items-center gap-3 px-4 py-2.5 border-b border-border text-xs text-muted-foreground">
        <span class="font-medium text-foreground">Industrial Agent Decision Support</span>
        <span class="text-foreground/30">|</span>
        <span>Agent</span>
        <span class="ml-auto">草稿进行中 &middot; 已保存到本地</span>
      </div>
      <div class="flex min-h-[280px]">
        <!-- Mock sidebar -->
        <div id="mock-sidebar-zh" role="tablist" aria-label="工作流步骤" class="w-44 shrink-0 border-r border-border p-3 space-y-2 text-xs">
          <button type="button" role="tab" aria-selected="true" data-step="1" class="mock-step w-full flex items-center gap-2 rounded-md px-1.5 py-1 transition-colors text-left cursor-pointer text-emerald-400 bg-emerald-500/5">
            <span class="w-5 h-5 rounded-full bg-emerald-500/20 flex items-center justify-center text-[10px] font-medium">1</span> 定义产品
          </button>
          <button type="button" role="tab" aria-selected="false" data-step="2" class="mock-step w-full flex items-center gap-2 rounded-md px-1.5 py-1 transition-colors text-left cursor-pointer text-muted-foreground hover:text-foreground hover:bg-secondary/50">
            <span class="w-5 h-5 rounded-full bg-secondary flex items-center justify-center text-[10px] font-medium">2</span> 设计 AI 工作流
          </button>
          <button type="button" role="tab" aria-selected="false" data-step="3" class="mock-step w-full flex items-center gap-2 rounded-md px-1.5 py-1 transition-colors text-left cursor-pointer text-muted-foreground hover:text-foreground hover:bg-secondary/50">
            <span class="w-5 h-5 rounded-full bg-secondary flex items-center justify-center text-[10px] font-medium">3</span> 评估与风险
          </button>
          <button type="button" role="tab" aria-selected="false" data-step="4" class="mock-step w-full flex items-center gap-2 rounded-md px-1.5 py-1 transition-colors text-left cursor-pointer text-muted-foreground hover:text-foreground hover:bg-secondary/50">
            <span class="w-5 h-5 rounded-full bg-secondary flex items-center justify-center text-[10px] font-medium">4</span> 导出交付材料
          </button>
        </div>

        <!-- Mock form panels -->
        <div class="flex-1 border-r border-border relative">
          <!-- Step 1: 定义产品 -->
          <div data-panel="1" role="tabpanel" class="mock-panel absolute inset-0 p-4 space-y-3 overflow-hidden">
            <div class="text-xs font-semibold uppercase tracking-wider text-foreground/50">问题背景</div>
            <div class="space-y-2">
              <div class="space-y-1"><div class="text-xs text-muted-foreground">业务场景</div><div class="h-14 rounded bg-secondary/50"></div></div>
              <div class="space-y-1"><div class="text-xs text-muted-foreground">目标用户</div><div class="h-9 rounded bg-secondary/50"></div></div>
              <div class="space-y-1"><div class="text-xs text-muted-foreground">需要支持的决策</div><div class="h-9 rounded bg-secondary/50"></div></div>
            </div>
          </div>
          <!-- Step 2: 设计 AI 工作流 -->
          <div data-panel="2" role="tabpanel" aria-hidden="true" class="mock-panel absolute inset-0 p-4 space-y-3 overflow-hidden opacity-0 pointer-events-none">
            <div class="text-xs font-semibold uppercase tracking-wider text-foreground/50">AI / 智能体工作流</div>
            <div class="space-y-2">
              <div class="space-y-1"><div class="text-xs text-muted-foreground">AI 能力</div><div class="h-9 rounded bg-secondary/50"></div></div>
              <div class="space-y-1"><div class="text-xs text-muted-foreground">智能体决策</div><div class="flex gap-2"><div class="h-8 flex-1 rounded bg-emerald-500/10 ring-1 ring-emerald-500/20"></div><div class="h-8 flex-1 rounded bg-secondary/50"></div></div></div>
              <div class="space-y-1"><div class="text-xs text-muted-foreground">工作流步骤</div><div class="h-16 rounded bg-secondary/50"></div></div>
              <div class="space-y-1"><div class="text-xs text-muted-foreground">人工审核</div><div class="h-9 rounded bg-secondary/50"></div></div>
            </div>
          </div>
          <!-- Step 3: 评估与风险 -->
          <div data-panel="3" role="tabpanel" aria-hidden="true" class="mock-panel absolute inset-0 p-4 space-y-3 overflow-hidden opacity-0 pointer-events-none">
            <div class="text-xs font-semibold uppercase tracking-wider text-foreground/50">评估与风险</div>
            <div class="space-y-2">
              <div class="space-y-1"><div class="text-xs text-muted-foreground">评估指标</div><div class="h-12 rounded bg-secondary/50"></div></div>
              <div class="space-y-1"><div class="text-xs text-muted-foreground">评估场景</div><div class="h-12 rounded bg-secondary/50"></div></div>
              <div class="space-y-1"><div class="text-xs text-muted-foreground">验收标准</div><div class="h-9 rounded bg-secondary/50"></div></div>
            </div>
          </div>
          <!-- Step 4: 导出 -->
          <div data-panel="4" role="tabpanel" aria-hidden="true" class="mock-panel absolute inset-0 p-4 space-y-3 overflow-hidden opacity-0 pointer-events-none">
            <div class="text-xs font-semibold uppercase tracking-wider text-foreground/50">导出文档</div>
            <div class="grid grid-cols-2 gap-2">
              <div class="rounded-lg ring-1 ring-foreground/8 p-2.5"><div class="text-[11px] font-medium text-foreground mb-0.5">AI 产品简报</div><div class="h-1.5 w-3/4 rounded bg-secondary"></div></div>
              <div class="rounded-lg ring-1 ring-foreground/8 p-2.5"><div class="text-[11px] font-medium text-foreground mb-0.5">工作流规格说明</div><div class="h-1.5 w-2/3 rounded bg-secondary"></div></div>
              <div class="rounded-lg ring-1 ring-foreground/8 p-2.5"><div class="text-[11px] font-medium text-foreground mb-0.5">评估方案</div><div class="h-1.5 w-3/4 rounded bg-secondary"></div></div>
              <div class="rounded-lg ring-1 ring-foreground/8 p-2.5"><div class="text-[11px] font-medium text-foreground mb-0.5">验收标准</div><div class="h-1.5 w-1/2 rounded bg-secondary"></div></div>
              <div class="rounded-lg ring-1 ring-foreground/8 p-2.5"><div class="text-[11px] font-medium text-foreground mb-0.5">编码智能体交付物</div><div class="h-1.5 w-2/3 rounded bg-secondary"></div></div>
              <div class="rounded-lg ring-1 ring-foreground/8 p-2.5"><div class="text-[11px] font-medium text-foreground mb-0.5">CLAUDE.md 起始模板</div><div class="h-1.5 w-3/5 rounded bg-secondary"></div></div>
            </div>
          </div>
        </div>

        <!-- Mock preview panels -->
        <div class="w-72 shrink-0 relative">
          <!-- Preview 1: 产品简报 -->
          <div data-preview="1" role="tabpanel" class="mock-preview absolute inset-0 p-4 overflow-hidden">
            <div class="text-xs font-semibold text-foreground/50 mb-2">实时预览</div>
            <div class="space-y-2 text-xs text-muted-foreground">
              <div class="font-semibold text-foreground text-sm">AI 产品简报</div>
              <div class="h-2 w-3/4 rounded bg-secondary"></div>
              <div class="h-2 w-full rounded bg-secondary"></div>
              <div class="h-2 w-5/6 rounded bg-secondary"></div>
              <div class="h-2 w-2/3 rounded bg-secondary"></div>
              <div class="mt-3 font-semibold text-foreground text-sm">业务问题</div>
              <div class="h-2 w-full rounded bg-secondary"></div>
              <div class="h-2 w-4/5 rounded bg-secondary"></div>
            </div>
          </div>
          <!-- Preview 2: 工作流规格说明 -->
          <div data-preview="2" role="tabpanel" aria-hidden="true" class="mock-preview absolute inset-0 p-4 overflow-hidden opacity-0 pointer-events-none">
            <div class="text-xs font-semibold text-foreground/50 mb-2">实时预览</div>
            <div class="space-y-2 text-xs text-muted-foreground">
              <div class="font-semibold text-foreground text-sm">工作流规格说明</div>
              <div class="h-2 w-4/5 rounded bg-secondary"></div>
              <div class="h-2 w-full rounded bg-secondary"></div>
              <div class="mt-3 flex items-center gap-1.5">
                <div class="h-5 w-16 rounded bg-emerald-500/15 ring-1 ring-emerald-500/20"></div>
                <div class="w-3 h-px bg-foreground/20"></div>
                <div class="h-5 w-16 rounded bg-emerald-500/15 ring-1 ring-emerald-500/20"></div>
                <div class="w-3 h-px bg-foreground/20"></div>
                <div class="h-5 w-16 rounded bg-emerald-500/15 ring-1 ring-emerald-500/20"></div>
              </div>
              <div class="mt-2 h-2 w-full rounded bg-secondary"></div>
              <div class="h-2 w-5/6 rounded bg-secondary"></div>
              <div class="mt-3 font-semibold text-foreground text-sm">工具与边界</div>
              <div class="h-2 w-full rounded bg-secondary"></div>
              <div class="h-2 w-3/4 rounded bg-secondary"></div>
            </div>
          </div>
          <!-- Preview 3: 评估方案 -->
          <div data-preview="3" role="tabpanel" aria-hidden="true" class="mock-preview absolute inset-0 p-4 overflow-hidden opacity-0 pointer-events-none">
            <div class="text-xs font-semibold text-foreground/50 mb-2">实时预览</div>
            <div class="space-y-2 text-xs text-muted-foreground">
              <div class="font-semibold text-foreground text-sm">评估方案</div>
              <div class="h-2 w-3/4 rounded bg-secondary"></div>
              <div class="h-2 w-full rounded bg-secondary"></div>
              <div class="mt-3 font-semibold text-foreground text-sm">测试场景</div>
              <div class="flex flex-wrap gap-1 mt-1">
                <div class="h-4 w-14 rounded-full bg-emerald-500/10"></div>
                <div class="h-4 w-16 rounded-full bg-emerald-500/10"></div>
                <div class="h-4 w-12 rounded-full bg-emerald-500/10"></div>
              </div>
              <div class="mt-2 font-semibold text-foreground text-sm">验收标准</div>
              <div class="h-2 w-full rounded bg-secondary"></div>
              <div class="h-2 w-4/5 rounded bg-secondary"></div>
            </div>
          </div>
          <!-- Preview 4: 导出 -->
          <div data-preview="4" role="tabpanel" aria-hidden="true" class="mock-preview absolute inset-0 p-4 overflow-hidden opacity-0 pointer-events-none">
            <div class="text-xs font-semibold text-foreground/50 mb-2">实时预览</div>
            <div class="space-y-3 text-xs text-muted-foreground">
              <div class="font-semibold text-foreground text-sm">设计审查</div>
              <div class="flex items-center gap-2">
                <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] bg-amber-500/15 text-amber-400 font-medium">1 警告</span>
                <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] bg-blue-500/15 text-blue-400 font-medium">2 建议</span>
              </div>
              <div class="mt-3 font-semibold text-foreground text-sm">生成文档</div>
              <div class="h-2 w-full rounded bg-secondary"></div>
              <div class="h-2 w-5/6 rounded bg-secondary"></div>
              <div class="h-2 w-4/5 rounded bg-secondary"></div>
              <div class="mt-3 flex gap-2">
                <div class="h-7 w-20 rounded-md bg-emerald-600/80"></div>
                <div class="h-7 w-20 rounded-md bg-secondary"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <p class="text-center text-xs text-muted-foreground mt-3">点击步骤 1–4 预览完整流程</p>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const container = document.getElementById('mock-sidebar-zh');
      if (!container) return;
      const buttons = container.parentElement!.querySelectorAll<HTMLButtonElement>('.mock-step');
      const section = container.closest('section')!;
      const panels = section.querySelectorAll<HTMLElement>('.mock-panel');
      const previews = section.querySelectorAll<HTMLElement>('.mock-preview');

      function switchStep(step: string) {
        buttons.forEach(btn => {
          const isActive = btn.dataset.step === step;
          const numSpan = btn.querySelector('span');
          btn.setAttribute('aria-selected', String(isActive));
          if (isActive) {
            btn.className = 'mock-step w-full flex items-center gap-2 rounded-md px-1.5 py-1 transition-colors text-left cursor-pointer text-emerald-400 bg-emerald-500/5';
            if (numSpan) numSpan.className = 'w-5 h-5 rounded-full bg-emerald-500/20 flex items-center justify-center text-[10px] font-medium';
          } else {
            btn.className = 'mock-step w-full flex items-center gap-2 rounded-md px-1.5 py-1 transition-colors text-left cursor-pointer text-muted-foreground hover:text-foreground hover:bg-secondary/50';
            if (numSpan) numSpan.className = 'w-5 h-5 rounded-full bg-secondary flex items-center justify-center text-[10px] font-medium';
          }
        });
        panels.forEach(p => {
          const isActive = p.dataset.panel === step;
          p.style.opacity = isActive ? '1' : '0';
          p.style.pointerEvents = isActive ? 'auto' : 'none';
          p.setAttribute('aria-hidden', String(!isActive));
        });
        previews.forEach(p => {
          const isActive = p.dataset.preview === step;
          p.style.opacity = isActive ? '1' : '0';
          p.style.pointerEvents = isActive ? 'auto' : 'none';
          p.setAttribute('aria-hidden', String(!isActive));
        });
      }

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          if (btn.dataset.step) switchStep(btn.dataset.step);
        });
      });
    });
  </script>

  <!-- Section 2: How It Works -->
  <section class="mb-20">
    <h2 class="text-xs font-semibold text-muted-foreground uppercase tracking-widest text-center mb-10">工作流程</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 relative">
      <!-- Connector line (desktop only) -->
      <div class="hidden md:block absolute top-6 left-[12.5%] right-[12.5%] h-px bg-foreground/10 z-0" />
      {steps.map((step) => (
        <div class="relative z-10 flex flex-col items-center text-center">
          <div class="w-12 h-12 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center text-lg font-bold mb-3">
            {step.num}
          </div>
          <h3 class="text-sm font-semibold text-foreground mb-1">{step.title}</h3>
          <p class="text-xs text-muted-foreground leading-relaxed m-0">{step.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Section 3: What You Get -->
  <section class="mb-20">
    <h2 class="text-xs font-semibold text-muted-foreground uppercase tracking-widest text-center mb-10">交付物清单</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
      {outputs.map((item) => (
        <div class="bg-card rounded-xl ring-1 ring-foreground/10 p-5">
          <div class="w-9 h-9 rounded-lg bg-emerald-500/10 flex items-center justify-center text-emerald-400 mb-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d={iconPaths[item.icon]} />
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-foreground mb-1">{item.title}</h3>
          <p class="text-xs text-muted-foreground leading-relaxed m-0">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Section 4: Example Concepts -->
  <section class="mb-20">
    <h2 class="text-xs font-semibold text-muted-foreground uppercase tracking-widest text-center mb-10">示例概念</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      {examples.map((ex) => (
        <div class="bg-card rounded-xl ring-1 ring-foreground/10 p-5 flex flex-col">
          <h3 class="text-sm font-semibold text-foreground mb-2">{ex.title}</h3>
          <div class="flex items-center gap-2 mb-2">
            <span class="inline-flex px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-400 text-[10px] font-medium">{ex.tag}</span>
            <span class="text-[10px] text-muted-foreground">&middot;</span>
            <span class="text-[10px] text-muted-foreground">{ex.scenario}</span>
          </div>
          <p class="text-xs text-muted-foreground leading-relaxed m-0 mb-4 flex-1">挑战：{ex.challenge}</p>
          <a
            href={`${base}zh-CN/workbench/`}
            onclick={`sessionStorage.setItem('ai-pm-load-example', '${ex.key}')`}
            class="inline-flex items-center gap-1.5 text-xs font-medium text-emerald-400 hover:text-emerald-300 transition-colors no-underline"
          >
            在快速工具中打开
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- Section 5: Case Modules -->
  <section class="mb-20">
